{% extends 'base.html.twig' %}

{% block title %}Liste des candidats{% endblock %}

{% block body %}
    <h1>Liste des candidats</h1>

    <a href="{{ path('candidat_new') }}" class="btn btn-success mb-3">Ajouter un candidat</a>

    <table class="table table-bordered">
        <thead>
        <tr>
            <th>Nom</th>
            <th>Prénom</th>
            <th>Email</th>
            <th>Téléphone</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        {% for candidat in candidats %}
            <tr>
                <td>{{ candidat.nom }}</td>
                <td>{{ candidat.prenom }}</td>
                <td>{{ candidat.email }}</td>
                <td>{{ candidat.telephone }}</td>
                <td>
                    <a href="{{ path('candidat_show', {'id': candidat.id}) }}" class="btn btn-info btn-sm">Voir</a>
                    <a href="{{ path('candidat_edit', {'id': candidat.id}) }}" class="btn btn-warning btn-sm">Modifier</a>

                    {# Formulaire suppression #}
                    <form method="post" action="{{ path('candidat_delete', {'id': candidat.id}) }}" style="display:inline-block;" onsubmit="return confirm('Voulez-vous vraiment supprimer ce candidat ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ candidat.id) }}">
                        <button class="btn btn-danger btn-sm">Supprimer</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Aucun candidat trouvé.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
