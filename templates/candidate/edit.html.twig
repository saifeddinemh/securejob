{% extends 'base.html.twig' %}

{% block title %}Modifier {{ candidate.firstName }} {{ candidate.lastName }}{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4"><i class="fas fa-edit"></i> Modifier le profil</h1>

        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h4 class="mb-0">Modification du profil</h4>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                <div class="row">
                    <div class="col-md-6">
                        {{ form_row(form.firstName) }}
                        {{ form_row(form.lastName) }}
                        {{ form_row(form.phone) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.address) }}
                        {{ form_row(form.city) }}
                        {{ form_row(form.postalCode) }}
                    </div>
                </div>
                {{ form_row(form.country) }}
                {{ form_row(form.bio) }}
                {{ form_row(form.skills) }}
                {{ form_row(form.isVisible) }}

                <div class="mt-3">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Enregistrer les modifications
                    </button>
                    <a href="{{ path('app_candidate_show', {'id': candidate.id}) }}" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Annuler
                    </a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
