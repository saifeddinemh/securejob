{% extends 'base.html.twig' %}

{% block title %}Nouveau Candidat - SecureJob{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4"><i class="fas fa-user-plus"></i> Nouveau Candidat</h1>

        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Créer un nouveau profil candidat</h4>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                <div class="row">
                    <div class="col-md-6">
                        {{ form_row(form.firstName, {'attr': {'class': 'form-control'}}) }}
                        {{ form_row(form.lastName, {'attr': {'class': 'form-control'}}) }}
                        {{ form_row(form.phone, {'attr': {'class': 'form-control'}}) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.city, {'attr': {'class': 'form-control'}}) }}
                        {{ form_row(form.country, {'attr': {'class': 'form-control'}}) }}
                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        {{ form_row(form.address, {'attr': {'class': 'form-control'}}) }}
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        {{ form_row(form.postalCode, {'attr': {'class': 'form-control'}}) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.isVisible, {'attr': {'class': 'form-check-input'}}) }}
                    </div>
                </div>

                {{ form_row(form.bio, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                {{ form_row(form.skills, {'attr': {'class': 'form-select'}}) }}

                <div class="mt-3">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Créer le profil
                    </button>
                    <a href="{{ path('app_candidate_index') }}" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Retour à la liste
                    </a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>

    <style>
        .form-control, .form-select {
            margin-bottom: 1rem;
        }
    </style>
{% endblock %}
